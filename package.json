{
  "name": "agent-trail",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "engines": {
    "bun": ">=1.3.11"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "check": "bun run typecheck && bun run lint && bun run test && bun pm ls --all >/dev/null && bun run --workspaces --sequential check",
    "format": "biome format --write",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "lefthook install",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.3.14",
    "bun-types": "1.3.14",
    "lefthook": "^2.1.6",
    "typescript": "^6.0.3"
  }
}
