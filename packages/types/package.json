{
  "name": "@agent-trail/types",
  "version": "0.0.0",
  "description": "TypeScript types generated from the Agent Trail schema.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "types": "./index.d.ts",
  "files": [
    "index.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-trail/agent-trail.git",
    "directory": "packages/types"
  },
  "bugs": {
    "url": "https://github.com/agent-trail/agent-trail/issues"
  },
  "homepage": "https://github.com/agent-trail/agent-trail#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "check": "bun ../../scripts/generate-types.ts --check && tsc --noEmit --project ../../tsconfig.json",
    "generate": "bun ../../scripts/generate-types.ts"
  }
}
