{
  "name": "@agent-trail/adapter-kit",
  "version": "0.0.0",
  "description": "Agent Trail shared adapter extraction primitives and source readers.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./bun-sqlite": {
      "types": "./src/readers/bun-sqlite-driver.ts",
      "default": "./src/readers/bun-sqlite-driver.ts"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agent-trail/agent-trail.git",
    "directory": "packages/adapter-kit"
  },
  "bugs": {
    "url": "https://github.com/agent-trail/agent-trail/issues"
  },
  "homepage": "https://github.com/agent-trail/agent-trail#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agent-trail/core": "workspace:*",
    "@agent-trail/source-schemas": "workspace:*",
    "ajv": "catalog:",
    "semver": "catalog:"
  },
  "devDependencies": {
    "@types/semver": "^7.5.8"
  },
  "scripts": {
    "check": "bun test && tsc --noEmit --project ../../tsconfig.json",
    "test": "bun test"
  }
}
